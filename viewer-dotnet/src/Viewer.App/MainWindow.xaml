<Window x:Class="Viewer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Entheus Stream Analytics Viewer"
        Height="600"
        Width="900"
        Background="#1B1F27"
        Loaded="OnLoaded">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="0" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Barra superior de control simple -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,4">
                <TextBlock Text="Layout de prueba:"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <ComboBox x:Name="LayoutSelector"
                          Width="120"
                          Height="28"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          SelectedIndex="0"
                          SelectionChanged="OnLayoutSelectionChanged">
                    <ComboBoxItem Content="2x2" />
                    <ComboBoxItem Content="3x3" />
                    <ComboBoxItem Content="4x4" />
                    <ComboBoxItem Content="4x5" />
                    <ComboBoxItem Content="5x4" />
                </ComboBox>

                <Button Content="Generar JSON de /infer"
                        Margin="16,0,0,0"
                        Padding="8,4"
                        Click="OnGenerateJsonClick" />

                <TextBlock Text="Perfil:"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="16,0,4,0" />
                <ComboBox x:Name="ProfileComboBox"
                          Width="200"
                          Height="28"
                          VerticalAlignment="Center"
                          DisplayMemberPath="Name" />
                <Button Content="Conectar perfil"
                        Margin="8,0,0,0"
                        Padding="8,4"
                        Click="OnConnectProfileClick" />
            </StackPanel>

            <!-- Botón de configuración de conexión RTSP tipo SmartPSS -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,4,0,0">
                <Button Content="Configurar conexión RTSP (SmartPSS)"
                        Padding="10,6"
                        Click="OnBuildSmartPssUrlClick" />
            </StackPanel>
        </Grid>

        <!-- Zona principal de grid de cámaras -->
        <Grid Grid.Row="1"
              Margin="0,0,0,4"
              Background="#11151C">
            <UniformGrid x:Name="CellsGrid"
                         Rows="2"
                         Columns="2" />
        </Grid>

        <!-- Panel simple de logs -->
        <TextBox x:Name="LogTextBox"
                 Grid.Row="2"
                 Height="0"
                 Background="#11151C"
                 Foreground="#D0D8E5"
                 BorderBrush="#252A34"
                 Margin="0"
                 Visibility="Collapsed"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" />
    </Grid>
</Window>

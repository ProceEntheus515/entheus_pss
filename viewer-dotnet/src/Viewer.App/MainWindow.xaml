<Window x:Class="Viewer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Entheus Stream Analytics Viewer"
        Height="600"
        Width="900"
        Background="#1B1F27"
        Loaded="OnLoaded">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Barra superior de control simple -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,4">
                <TextBlock Text="Layout de prueba:"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <ComboBox x:Name="LayoutSelector"
                          Width="120"
                          Height="28"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          SelectedIndex="0"
                          SelectionChanged="OnLayoutSelectionChanged">
                    <ComboBoxItem Content="1x1" />
                    <ComboBoxItem Content="2x2" />
                    <ComboBoxItem Content="3x3" />
                </ComboBox>

                <Button Content="Generar JSON de /infer"
                        Margin="16,0,0,0"
                        Padding="8,4"
                        Click="OnGenerateJsonClick" />
            </StackPanel>

            <!-- Constructor de enlaces RTSP tipo SmartPSS -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,4,0,0">
                <TextBlock Text="Sistema:"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0" />
                <ComboBox x:Name="SystemSelector"
                          Width="150"
                          Height="28"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0">
                    <ComboBoxItem Content="SmartPSS (Dahua)"
                                  IsSelected="True" />
                </ComboBox>

                <TextBlock Text="Usuario:"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0" />
                <TextBox x:Name="RtspUserTextBox"
                         Width="90"
                         Margin="0,0,8,0" />

                <TextBlock Text="Password:"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0" />
                <PasswordBox x:Name="RtspPasswordBox"
                             Width="90"
                             Margin="0,0,8,0" />

                <TextBlock Text="IP / host:"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0" />
                <TextBox x:Name="RtspHostTextBox"
                         Width="120"
                         Margin="0,0,8,0" />

                <TextBlock Text="Puerto:"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0" />
                <TextBox x:Name="RtspPortTextBox"
                         Width="60"
                         Margin="0,0,8,0"
                         Text="554" />

                <Button Content="Construir enlace SmartPSS"
                        Margin="8,0,0,0"
                        Padding="8,4"
                        Click="OnBuildSmartPssUrlClick" />
            </StackPanel>
        </Grid>

        <!-- Zona principal de grid de cámaras -->
        <Grid Grid.Row="1"
              Margin="0,0,0,4"
              Background="#11151C">
            <UniformGrid x:Name="CellsGrid"
                         Rows="2"
                         Columns="2" />
        </Grid>

        <!-- Panel simple de logs -->
        <TextBox x:Name="LogTextBox"
                 Grid.Row="2"
                 Height="80"
                 Background="#11151C"
                 Foreground="#D0D8E5"
                 BorderBrush="#252A34"
                 Margin="0"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" />
    </Grid>
</Window>
